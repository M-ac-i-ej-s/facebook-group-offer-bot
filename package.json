{
  "name": "facebook-group-offer-bot",
  "version": "1.0.0",
  "description": "A bot that monitors Facebook groups for specific keywords and posts automatic comments",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run electron-dev\" \"npm run react-dev\"",
    "electron-dev": "cross-env NODE_ENV=development electron .",
    "react-dev": "cross-env NODE_ENV=development node ./electron/dev-server.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "configure": "node configure.js",
    "bot": "node bot.js"
  },
  "keywords": ["facebook", "bot", "automation", "groups"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^21.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^24.0.0",
    "electron-dev": "^1.0.1",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.facebookgroupbot.app",
    "productName": "Facebook Group Offer Bot",
    "files": [
      "electron/**/*",
      "src/**/*",
      "dist/**/*",
      "bot.js",
      "bot-module.js",
      ".env.example",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}.exe"
    }
  }
}
