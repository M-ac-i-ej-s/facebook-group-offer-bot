# Facebook credentials
FB_EMAIL=your_email@facebook.com
FB_PASSWORD=your_password

# Facebook group URLs (add more as needed)
FB_GROUP_URL_1=https://www.facebook.com/groups/your_group_id/

# Keywords to search for (comma-separated, case-insensitive)
FB_KEYWORDS=keyword1,keyword2,keyword3

# Comment to post when keywords are found
FB_COMMENT=Thanks for sharing! This looks great.

# Check interval in milliseconds (default: 300000 = 5 minutes)
CHECK_INTERVAL=300000
